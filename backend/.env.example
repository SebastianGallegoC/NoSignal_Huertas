ENVIRONMENT="development"
APP_NAME="NoSignal API"
API_V1_PREFIX="/api/v1"
JWT_SECRET="REEMPLAZAR_CON_SECRETO_LARGO_Y_ALEATORIO"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES=480
# JSON de usuarios para login MVP. Soporta hash bcrypt o prefijo plain: (temporal).
NOSIGNAL_AUTH_USERS={"admin":"REEMPLAZAR_HASH_BCRYPT"}
# En producción incluir el origen del frontend, p. ej. https://nosignal.site
CORS_ORIGINS=http://localhost:5173
# Opcional: regex si tenés varios orígenes (previews, subdominios). Ej.: https://.*\\.nosignal\\.site
# CORS_ORIGIN_REGEX=
DATABASE_URL="postgresql+asyncpg://nosignal:REEMPLAZAR_PASSWORD@localhost:5432/nosignal"
UPLOAD_ROOT="uploads"
ALLOW_INSECURE_DEFAULTS=true
AUTO_CREATE_SCHEMA=true
